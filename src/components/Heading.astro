---
const { htmlheading = "h2", size = "h2", stylingclasses = "" } = Astro.props;
const Htmlheading = htmlheading;

const sizeClasses = {
  h1: "text-[5rem] leading-[4.775rem] font-main font-bold",
  h2: "text-[2.5rem] leading-[3.606rem] font-main font-bold",
  h3: "text-[2.25rem] leading-[3.625rem] font-main font-bold",

  dato: "text-[9.125rem] leading-[8.375rem] font-main font-bold",

  displayhero: "text-[8.125rem] leading-none font-chalk",
  displaymenu: "text-[8.438rem] leading-[4.775rem] font-chalk",
  displayfooter: "text-[28.125rem] leading-[4.8rem] font-chalk",

  footerh2: "text-[1.75rem] leading-[2.956rem] font-main font-bold",
  menukorth3: "text-[1.519rem] leading-[1.813rem] font-main font-bold",

  // MOBILE

  mh1: "text-[1.875rem] leading-[1.938rem] font-main font-bold",
  mh2: "text-[1.438rem] leading-[1.5rem] font-main font-bold",
  mdato: "text-[3rem] leading-[3.756rem] font-main font-bold",

  mdisplayhero: "text-[4rem] leading-none font-chalk",
  mdisplayfooter: "text-[7.475rem] leading-[1.275rem] font-chalk",

  mfooterh2: "text-[1.125rem] leading-[1.825rem] font-main font-bold",
  mmenukorth3: "text-[0.938rem] leading-[1.125rem] font-main font-bold",
};
---

<Htmlheading class:list={[sizeClasses[size], stylingclasses]}>
  <slot />
</Htmlheading>
